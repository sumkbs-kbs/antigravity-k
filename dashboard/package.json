{
  "name": "antigravity-k-dashboard-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Antigravity-K Dashboard — React + TypeScript",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "stryker": "stryker run",
    "stryker:quick": "stryker run --mutate 'src/stores/terminalStore.ts' --mutate 'src/stores/outputStore.ts'",
    "e2e": "npx playwright test",
    "e2e:headed": "E2E_HEADED=1 npx playwright test",
    "e2e:report": "npx playwright show-report e2e-report"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/diff": "^7.0.2",
    "diff": "^9.0.0",
    "dompurify": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.1.0",
    "rehype-highlight": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "split.js": "^1.6.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/split.js": "^1.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
