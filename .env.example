# Antigravity-K Environment Variables
# =====================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Backend Server ────────────────────────────────────────────
AGK_HOST=0.0.0.0
AGK_PORT=8000
AGK_RELOAD=true

# ─── Security ──────────────────────────────────────────────────
# Access PIN for API authentication (leave empty to disable)
AGK_ACCESS_PIN=

# Allowed CORS origins (comma-separated, empty = no CORS restriction)
# Example: http://localhost:5173,http://localhost:8080
AGK_CORS_ORIGINS=http://localhost:5173

# ─── LLM Provider ──────────────────────────────────────────────
# Primary inference provider (ollama | openrouter | nim | openai | gemini | zai)
AGK_PROVIDER=openrouter
AGK_API_KEY=
AGK_MODEL=qwen3-72b

# ─── OpenRouter (다중 모델聚合) ────────────────────────────────
# https://openrouter.ai/에서 발급
OPENROUTER_API_KEY=

# ─── NVIDIA NIM (build.nvidia.com 무료 API) ────────────────────
# 무료 키 발급: https://build.nvidia.com/ → API Keys (무료, 40rpm/1000req-day)
# 80+ 모델(DeepSeek-R1, Llama 3.1 405B, Nemotron 등)을 무료로 사용 가능
NVIDIA_API_KEY=

# ─── OpenAI 직접 ───────────────────────────────────────────────
# https://platform.openai.com/api-keys에서 발급
# GPT-4o, GPT-4o-mini, o3-mini 등
OPENAI_API_KEY=

# ─── Google Gemini 직접 ────────────────────────────────────────
# https://aistudio.google.com/apikey에서 발급
# Gemini 2.0 Flash, Gemini 2.5 Pro 등
GEMINI_API_KEY=

# ─── ZAI / Zhipu GLM 직접 ──────────────────────────────────────
# https://open.bigmodel.cn/에서 발급
# GLM-4-Plus, GLM-4-Air 등 (한국어 강점)
ZAI_API_KEY=

# ─── Local Model (MLX) ─────────────────────────────────────────
AGK_LOCAL_MODEL_PATH=models/
AGK_LOCAL_MODEL=

# ─── RAG / Vector Store ────────────────────────────────────────
AGK_CHROMA_PATH=vault_data/.chroma
AGK_EMBEDDING_MODEL=

# ─── Monitoring ────────────────────────────────────────────────
AGK_LOG_LEVEL=INFO
AGK_LOG_FILE=logs/agent_json.log
AGK_ENABLE_AUDIT=true

# ─── Cost Control ──────────────────────────────────────────────
AGK_DAILY_BUDGET_USD=50.0
AGK_HOURLY_ACTION_LIMIT=100

# ─── GitHub (CI / Benchmark) ───────────────────────────────────
GITHUB_TOKEN=
