# Antigravity-K Environment Variables
# =====================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Backend Server ────────────────────────────────────────────
AGK_HOST=0.0.0.0
AGK_PORT=8000
AGK_RELOAD=true

# ─── Security ──────────────────────────────────────────────────
# Access PIN for API authentication (leave empty to disable)
AGK_ACCESS_PIN=

# Allowed CORS origins (comma-separated, empty = no CORS restriction)
# Example: http://localhost:5173,http://localhost:8080
AGK_CORS_ORIGINS=http://localhost:5173

# ─── LLM Provider ──────────────────────────────────────────────
# Primary inference provider
AGK_PROVIDER=openrouter
AGK_API_KEY=
AGK_MODEL=qwen3-72b

# ─── Local Model (MLX) ─────────────────────────────────────────
AGK_LOCAL_MODEL_PATH=models/
AGK_LOCAL_MODEL=

# ─── RAG / Vector Store ────────────────────────────────────────
AGK_CHROMA_PATH=vault_data/.chroma
AGK_EMBEDDING_MODEL=

# ─── Monitoring ────────────────────────────────────────────────
AGK_LOG_LEVEL=INFO
AGK_LOG_FILE=logs/agent_json.log
AGK_ENABLE_AUDIT=true

# ─── Cost Control ──────────────────────────────────────────────
AGK_DAILY_BUDGET_USD=50.0
AGK_HOURLY_ACTION_LIMIT=100

# ─── GitHub (CI / Benchmark) ───────────────────────────────────
GITHUB_TOKEN=
